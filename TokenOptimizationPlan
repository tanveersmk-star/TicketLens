    PDF["📄 Raw PDF<br>~58K tokens"] --> C1["Call 1: User Extract<br>+ Merge into Call 2"]
    PDF --> C2["Call 2: Review/Timeline<br>~58K input"]
    C2 --> JSON["📊 Structured JSON<br>~4-6K tokens"]
    JSON --> C3["Call 3: SM Analysis<br>~6K input"]
    JSON --> C4["Call 4: EA Analysis<br>~6K input"]
    
